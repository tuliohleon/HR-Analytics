model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: es-CO
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["DimEducationLevel","DimEmployee","FactPerformanceRating","DimRatingLevel","DimSatisfiedLevel"]

annotation PBI_ProTooling = ["DevMode"]

ref table DimEducationLevel
ref table DimEmployee
ref table FactPerformanceRating
ref table DimRatingLevel
ref table DimSatisfiedLevel
ref table DimDate

ref cultureInfo en-US

